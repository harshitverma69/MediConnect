# Copy to .env in this folder. Restart Vite after changes.

# Backend API — must be your Node/Express base URL only (no /api suffix, no trailing slash).
# Production: https://YOUR-EXPRESS-SERVICE.onrender.com  (same host as login/doctors; NOT the Vite frontend URL).
# AI routes: /api/ai/symptoms and /api/ai/predict (backend needs AI_SERVICE_URL for the Python service).
VITE_BACKEND_URL=http://localhost:4000

# Razorpay Checkout — use the same Key ID as backend RAZORPAY_KEY_ID (Test/Live mode must match)
VITE_RAZORPAY_KEY_ID=
