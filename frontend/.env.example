# Copy to .env in this folder. Restart Vite after changes.

# Backend API (defaults to http://localhost:4000 if unset).
# AI predictor uses the same backend: /api/ai/symptoms and /api/ai/predict (set AI_SERVICE_URL on the server).
VITE_BACKEND_URL=http://localhost:4000

# Razorpay Checkout — use the same Key ID as backend RAZORPAY_KEY_ID (Test/Live mode must match)
VITE_RAZORPAY_KEY_ID=
