# ─── Setup ─────────────────────────────────────────────────
# 1. Copy this file to:  backend/.env   (same directory as this example)
# 2. Fill MONGODB_URI + JWT_SECRET at minimum (see below)
# 3. From backend folder:  npm install && npm run server
# ───────────────────────────────────────────────────────────

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/

JWT_SECRET=change-this-to-any-long-random-string

# Cloudinary (needed for profile / doctor images). Use real keys from dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# If Add doctor / image upload fails with "unable to get local issuer certificate":
# 1) Prefer pointing Node at your CA bundle (corporate proxy / custom root):
#    NODE_EXTRA_CA_CERTS=/absolute/path/to/your-root-ca.pem
# 2) Last resort for local dev only (insecure for any shared or prod host):
#    CLOUDINARY_TLS_SKIP_VERIFY=1

ADMIN_EMAIL=admin@mediconnect.com
ADMIN_PASSWORD=admin123

# Stripe (optional — patient "Pay online" only works if set)
STRIPE_SECRET_KEY=
CURRENCY=inr

PORT=4000
